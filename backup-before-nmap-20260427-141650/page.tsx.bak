    os: 'Ubuntu Linux',
    environment: 'Vulnerable Target',
    riskLevel: 'Critical',
    lastSeen: '2026-04-24',
    openPortsServices: '21/tcp FTP, 22/tcp SSH, 139/tcp SMB, 445/tcp SMB',
    notes: 'Intentionally vulnerable VM. Isolated from production network.',
  },
  {
    id: 'asset-3',
    hostname: 'windows-test-host',
