export const runtime = "nodejs";

import { spawn } from "child_process";
import { getNmapPath } from "@/lib/nmapPath";
import { buildValidatedNmapArgs } from "@/lib/scanValidator";
import { parseNmapXml, generateFindings } from "@/lib/parseNmapXml";
import { saveScan } from "@/lib/scanStore";
import { scanPolicy } from "@/lib/scanPolicy";

function runNmap(args) {
  return new Promise((resolve, reject) => {
    const startedAt = Date.now();
    const nmapPath = getNmapPath();

    const nmap = spawn(nmapPath, args, {
      windowsHide: true,
    });

    let stdout = "";
    let stderr = "";
    let settled = false;

    const timeout = setTimeout(() => {
      if (!settled) {
        settled = true;
        nmap.kill();
        reject(new Error("Scan timed out."));
      }
    }, scanPolicy.defaultTimeoutSeconds * 1000);

    nmap.stdout.on("data", (data) => {
      stdout += data.toString();
    });

    nmap.stderr.on("data", (data) => {
      stderr += data.toString();
    });

    nmap.on("error", (error) => {
      if (!settled) {
        settled = true;
        clearTimeout(timeout);
        reject(error);
      }
    });

    nmap.on("close", (code) => {
      if (settled) return;

      settled = true;
      clearTimeout(timeout);

      const durationMs = Date.now() - startedAt;

      if (code !== 0) {
        reject(new Error(stderr || `Nmap exited with code ${code}.`));
        return;
      }

      resolve({
        stdout,
        stderr,
        durationMs,
      });
    });
  });
}

export async function POST(request) {
  try {
    const payload = await request.json();
    const validation = buildValidatedNmapArgs(payload);

    if (!validation.ok) {
      return Response.json(
        {
          status: "failed",
          error: validation.error,
        },
        {
          status: 400,
        }
      );
    }

    const startedAt = new Date().toISOString();
    const result = await runNmap(validation.args);
    const completedAt = new Date().toISOString();

    const parsed = parseNmapXml(result.stdout);
    const findings = generateFindings(parsed);

    const scan = {
      id: `scan-${Date.now()}`,
      target: payload.target,
      modeId: payload.modeId,
      modeName: validation.mode.name,
      args: validation.args,
      safeCommandPreview: validation.safeCommandPreview,
      status: "completed",
      startedAt,
      completedAt,
      durationMs: result.durationMs,
      rawOutput: result.stdout,
      stderr: result.stderr,
      parsed,
      findings,
      notes: payload.notes || "",
    };

    await saveScan(scan);

    return Response.json({ scan });
  } catch (error) {
    const message = error?.message || "Scan failed.";

    if (message.includes("ENOENT")) {
      return Response.json(
        {
          status: "failed",
          error: "Nmap is not installed or not found in PATH.",
          installHelp: "Install with: winget install Insecure.Nmap",
        },
        {
          status: 500,
        }
      );
    }

    return Response.json(
      {
        status: "failed",
        error: message,
      },
      {
        status: 500,
      }
    );
  }
}
